# Copy to /etc/qrsurvey.env (referenced by qrsurvey.service) and fill in.

ADDR=:8080
DB_PATH=/opt/qrsurvey/data/qrsurvey.db
QR_CACHE_DIR=/opt/qrsurvey/data/qrcodes
BASE_URL=https://survey.example.com

ADMIN_USER=admin
# bcrypt hash of the admin password — generate with:
#   go run ./cmd/hashpw 'your-password-here'
ADMIN_PASS_HASH=

# HMAC key for the non-guessable direct-entry (alternate method of entry)
# URLs — generate with: openssl rand -hex 32
HASH_SECRET=
